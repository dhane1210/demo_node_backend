# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_PATH=./data/logistics.db

# Sinay / SafeCube API
SINAY_API_KEY=your_api_key_here
SINAY_API_BASE_URL=https://api.sinay.ai/container-tracking/api/v2

# Webhooks (Svix)
WEBHOOK_SECRET=your_webhook_secret_here

# SMTP (Email)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASS=your_password_here
SMTP_FROM=noreply@logistics.com

# Sync Schedule (cron expression)
SYNC_CRON_SCHEDULE=0 */4 * * *
